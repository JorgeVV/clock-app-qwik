{
  "name": "clock-app",
  "description": "File based routing and MDX support Vite.js tooling. Netlify Edge Functions. Prettier code formatter. Tailwind CSS framework.",
  "scripts": {
    "postinstall": "patch-package",
    "build": "qwik build",
    "build.client": "vite build",
    "build.server": "vite build --ssr src/entry.netlify-edge.tsx",
    "build.types": "tsc --incremental --noEmit",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "serve": "netlify dev",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^0.9.0",
    "@builder.io/qwik-city": "^0.0.111",
    "@netlify/vite-plugin-netlify-edge": "1.1.0",
    "@types/eslint": "8.4.6",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "^5.38.1",
    "@typescript-eslint/parser": "^5.38.1",
    "autoprefixer": "^10.4.12",
    "eslint": "^8.24.0",
    "eslint-plugin-qwik": "^0.9.0",
    "node-fetch": "3.2.10",
    "patch-package": "^6.4.7",
    "postcss": "^8.4.17",
    "postcss-hover-media-feature": "^1.0.2",
    "prettier": "2.7.1",
    "tailwindcss": "^3.1.8",
    "tailwindcss-logical": "^3.0.0",
    "typescript": "^4.8.4",
    "vite": "^3.1.4",
    "vite-tsconfig-paths": "^3.5.1"
  },
  "engines": {
    "node": "^14.18.0 || >=16.0.0"
  },
  "homepage": "https://qwik.builder.io/",
  "license": "",
  "private": true,
  "type": "module",
  "dependencies": {
    "flip-toolkit": "^7.0.17",
    "remix-utils": "^3.3.0"
  }
}
